<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER"
      spacing="16"
      xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.devops.puissance4.controller.LoginController"
      style="-fx-background-color: linear-gradient(to bottom, #f8f9fb, #e9edf3);">

    <padding>
        <Insets top="40" right="40" bottom="40" left="40"/>
    </padding>

    <Label text="Puissance 4"
           style="-fx-font-size: 32px; -fx-font-weight: bold; -fx-text-fill: #1c1c1e;" />

    <Label text="Connexion ou création de compte"
           style="-fx-font-size: 14px; -fx-text-fill: #6e6e73;" />

    <VBox spacing="12" maxWidth="320"
          style="-fx-background-color: white; -fx-padding: 24; -fx-background-radius: 18; -fx-border-radius: 18; -fx-border-color: #dcdce1;">

        <TextField fx:id="usernameField"
                   promptText="Nom d'utilisateur"
                   style="-fx-background-radius: 10; -fx-padding: 12;" />

        <PasswordField fx:id="passwordField"
                       promptText="Mot de passe"
                       style="-fx-background-radius: 10; -fx-padding: 12;" />

        <Label fx:id="messageLabel"
               wrapText="true"
               style="-fx-text-fill: #c62828; -fx-font-size: 12px;" />

        <Button text="Se connecter"
                maxWidth="Infinity"
                onAction="#handleLogin"
                style="-fx-background-color: #111827; -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold; -fx-background-radius: 10; -fx-padding: 12;" />

        <Button text="Créer un compte"
                maxWidth="Infinity"
                onAction="#handleRegister"
                style="-fx-background-color: #e5e7eb; -fx-text-fill: #111827; -fx-font-size: 14px; -fx-font-weight: bold; -fx-background-radius: 10; -fx-padding: 12;" />
    </VBox>
</VBox>